{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "migrate": "dotenv -e .env -- node-pg-migrate up --config-file=database.config.json",
    "migrate:down": "dotenv -e .env -- node-pg-migrate down --config-file=database.config.json",
    "migrate:create": "dotenv -e .env -- node-pg-migrate create --config-file=database.config.json",
    "types:gen": "dotenv -e .env -- kanel",
    "seed": "dotenv -e .env -- tsx src/db/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "kanel": "^4.0.2",
    "kanel-zod": "^4.0.0",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "postgres": "^3.4.9",
    "styled-components": "^6.4.3",
    "zod": "^4.4.3"
  }
}
